#!/usr/bin/env bash
# osm-stdio — forced-command target for the restricted `osm` SSH user.
#
# Design notes
# ------------
# This script has TWO call sites:
#
#   1. Via sshd ForceCommand / authorized_keys command="…" (the main path):
#      sshd sets SSH_ORIGINAL_COMMAND to whatever the client passed as the
#      remote command ("17", "18", or "19"). The first positional arg $1 is
#      absent in this case.
#
#   2. Direct invocation for testing:  scripts/osm-stdio 18
#      Here $1 is the version; SSH_ORIGINAL_COMMAND is unset.
#
# server-setup.sh installs a thin shim at /usr/local/bin/osm-stdio that
# exec-s this file with the correct repo path baked in.
# Running this script standalone (from a checkout) is supported and useful
# for developer testing.
#
# Python runtime
# --------------
# When running as the restricted `osm` Linux user (the main production path),
# server-setup.sh builds a dedicated venv at /home/osm/venv and this script
# uses /home/osm/venv/bin/python directly — no uv required at request time.
#
# For direct/test invocation from a developer checkout (no /home/osm/venv),
# the script falls back to `uv run python` if /home/osm/venv/bin/python does
# not exist.  The venv path is controlled by the OSM_VENV env var
# (default: /home/osm/venv), which server-setup.sh bakes into the shim.
#
# PostgreSQL auth
# ---------------
# DATABASE_URL=postgresql:///osm_<ver> uses the local Unix socket and relies
# on the `osm` PostgreSQL role having access to the DB via peer authentication
# (Linux user `osm` → PG role `osm`).  server-setup.sh adds the following
# line to pg_hba.conf:
#
#   local   osm_17,osm_18,osm_19   osm   peer
#
# No password is stored in this script. If you switch to password auth,
# write a ~osm/.pgpass file (mode 600, owned by osm) — libpq reads it
# automatically and no changes here are needed.

set -euo pipefail

# ---------- version selection ----------
ver="${1:-${SSH_ORIGINAL_COMMAND:-}}"

if [[ -z "$ver" ]]; then
  >&2 echo "osm-stdio: no version given, defaulting to 17 (pass 17|18|19 to be explicit)"
  ver=17
fi

case "$ver" in
  17|18|19) ;;
  *)
    printf 'usage: ssh osm@host <17|18|19>\n' >&2
    exit 64
    ;;
esac

# ---------- locate the repo root ----------
# Resolve the real path of this script so we can find the repo root even
# when invoked via a symlink or the /usr/local/bin/osm-stdio shim.
_script_real="$(readlink -f "${BASH_SOURCE[0]}")"
_repo_root="$(cd "$(dirname "$_script_real")/.." && pwd)"

# ---------- run the MCP server ----------
# OSM_VENV is set by the shim generated by server-setup.sh.
# For standalone developer usage it falls back to /home/osm/venv, and then
# to uv if that venv doesn't exist either.
OSM_VENV="${OSM_VENV:-/home/osm/venv}"

if [[ -x "${OSM_VENV}/bin/python" ]]; then
  cd "$_repo_root"
  exec env DATABASE_URL="postgresql:///osm_${ver}" \
    "${OSM_VENV}/bin/python" -m osm.server.app
else
  # Developer fallback: no dedicated venv present, try uv.
  if command -v uv >/dev/null 2>&1; then
    _uv="$(command -v uv)"
  elif [[ -x "${HOME}/.local/bin/uv" ]]; then
    _uv="${HOME}/.local/bin/uv"
  elif [[ -x "/usr/local/bin/uv" ]]; then
    _uv="/usr/local/bin/uv"
  else
    printf 'osm-stdio: %s not found and uv not found.\n' "${OSM_VENV}/bin/python" >&2
    printf 'Run server-setup.sh to build the server venv, or install uv for dev use.\n' >&2
    exit 1
  fi
  cd "$_repo_root"
  exec env DATABASE_URL="postgresql:///osm_${ver}" \
    "$_uv" run python -m osm.server.app
fi
